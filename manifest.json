{
  "manifest_version": 3,
  "name": "Live Video Noise Remover",
  "version": "1.0",
  "description": "Removes background noise from videos on any website",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
